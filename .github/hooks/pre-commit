#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT_DIR"

CHANGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR || true)"
if [[ -z "$CHANGED_FILES" ]]; then
  exit 0
fi

CHATARCHIVE_PATTERN='^(pkg/chatarchive/|internal/chatarchivecmd/|cmd/create/chat_archive.go|cmd/backup/chats.go|test/e2e/|scripts/chatarchive-ci.sh|package.json|\.github/hooks/pre-commit|\.github/hooks/setup-hooks.sh|scripts/install-git-hooks.sh|\.github/workflows/chatarchive-quality.yml)'
if ! printf '%s\n' "$CHANGED_FILES" | grep -Eq "$CHATARCHIVE_PATTERN"; then
  exit 0
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "npm is required to run the chat archive pre-commit checks." >&2
  exit 1
fi

echo "Running chat archive validation via npm run ci"
npm run ci
